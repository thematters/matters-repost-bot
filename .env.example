# Copy this file to .env for local testing. .env is gitignored.
# In GitHub Actions, set these as repo Secrets (Settings → Secrets and variables → Actions).

MATTERS_EMAIL=your-matters-account@example.com
MATTERS_PASSWORD=your-matters-password

# Optional knobs:
# DRY_RUN=true              # skip all Matters API calls
# PUBLISH=true              # publish immediately instead of leaving as drafts
# MAX_ARTICLES_PER_RUN=10   # cap per run
